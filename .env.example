# Copy to .env and fill in.

# --- LLM / Embeddings ---
# Providers: openai | ollama | offline
INSIGHTRAG_LLM_PROVIDER=ollama
INSIGHTRAG_CHAT_MODEL=qwen2.5:7b
INSIGHTRAG_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional OpenAI (only if INSIGHTRAG_LLM_PROVIDER=openai)
OPENAI_API_KEY=
INSIGHTRAG_EMBED_MODEL=text-embedding-3-small

# Force extractive/templates-only mode (no generative model)
INSIGHTRAG_OFFLINE=false

# --- Postgres (Docker) — when set, warehouse + pgvector index use Postgres
# Start with: make docker-up && make demo-docker
# INSIGHTRAG_DATABASE_URL=postgresql://insightrag:insightrag@localhost:5432/insightrag

# --- SQLite fallback (when DATABASE_URL is unset) ---
INSIGHTRAG_DATA_DIR=data
INSIGHTRAG_INDEX_DIR=data/index
INSIGHTRAG_DB_PATH=data/warehouse.db

# --- Retrieval ---
INSIGHTRAG_TOP_K=5
INSIGHTRAG_CHUNK_SIZE=800
INSIGHTRAG_CHUNK_OVERLAP=120
INSIGHTRAG_HYBRID_ALPHA=0.5

# --- UI: route Streamlit through FastAPI (optional) ---
# INSIGHTRAG_API_URL=http://localhost:8000
